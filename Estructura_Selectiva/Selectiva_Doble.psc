Algoritmo Selectiva_Doble
	//Ingresar la edad y determinar si es 
	//MAYOR o MENOR de edad.
	Definir edad Como Entero;
	Escribir "Ingresar tu edad :";
	leer edad;
	//SELECTIVA DOBLE
	Si edad >= 18 entonces 
		escribir "Eres MAYOR de edad",edad;
	SiNo
		Escribir"Eres MENOR de edad",edad;
	FinSi	
FinAlgoritmo
